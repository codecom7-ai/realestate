# ═══════════════════════════════════════════════════════════════
# تطبيق المكتب العقاري المصري - Single-Tenant
# ═══════════════════════════════════════════════════════════════

# App
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Setup State (تُحدَّث تلقائياً بعد Setup Wizard)
SETUP_DONE=false
ORG_ID=

# ═══════════════════════════════════════════════════════════════
# Database
# ═══════════════════════════════════════════════════════════════
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/realestate_os

# ═══════════════════════════════════════════════════════════════
# Redis
# ═══════════════════════════════════════════════════════════════
REDIS_URL=redis://localhost:6379

# ═══════════════════════════════════════════════════════════════
# JWT (RS256) - توليد المفاتيح: ssh-keygen -t rsa -b 4096 -m PEM -f jwt.key
# ═══════════════════════════════════════════════════════════════
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_PUBLIC_KEY_HERE\n-----END PUBLIC KEY-----"

# ═══════════════════════════════════════════════════════════════
# Encryption (AES-256-GCM)
# ═══════════════════════════════════════════════════════════════
ENCRYPTION_KEY=your-32-character-encryption-key

# ═══════════════════════════════════════════════════════════════
# ETA (الفوترة الإلكترونية المصرية) - من بوابة ETA
# ═══════════════════════════════════════════════════════════════
ETA_IDENTITY_URL=https://id.preprod.eta.gov.eg
ETA_API_URL=https://api.preprod.invoicing.eta.gov.eg
ETA_CLIENT_ID=your-client-id
ETA_CLIENT_SECRET=your-client-secret
ETA_PRESHARED_KEY=your-preshared-key

# ═══════════════════════════════════════════════════════════════
# AI Providers
# ═══════════════════════════════════════════════════════════════
ANTHROPIC_API_KEY=sk-ant-your-key
GOOGLE_AI_API_KEY=AIza-your-key
OPENROUTER_API_KEY=sk-or-your-key
MINIMAX_API_KEY=your-minimax-key

# ═══════════════════════════════════════════════════════════════
# Payments
# ═══════════════════════════════════════════════════════════════
PAYMOB_API_KEY=your-paymob-key
FAWRY_MERCHANT_CODE=your-merchant-code
FAWRY_SECURITY_HASH=your-security-hash

# ═══════════════════════════════════════════════════════════════
# Storage (Cloudflare R2)
# ═══════════════════════════════════════════════════════════════
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY=your-access-key
R2_SECRET_KEY=your-secret-key
R2_BUCKET_NAME=realestate-os
R2_PUBLIC_URL=https://your-bucket.your-account.r2.cloudflarestorage.com

# ═══════════════════════════════════════════════════════════════
# WhatsApp Business API
# ═══════════════════════════════════════════════════════════════
WHATSAPP_TOKEN=your-whatsapp-token
WHATSAPP_PHONE_ID=your-phone-id
WHATSAPP_VERIFY_TOKEN=your-verify-token

# ═══════════════════════════════════════════════════════════════
# n8n Automation
# ═══════════════════════════════════════════════════════════════
N8N_URL=http://localhost:5678
N8N_API_KEY=your-n8n-api-key

# ═══════════════════════════════════════════════════════════════
# Firebase (Push Notifications)
# ═══════════════════════════════════════════════════════════════
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# ═══════════════════════════════════════════════════════════════
# Monitoring
# ═══════════════════════════════════════════════════════════════
SENTRY_DSN=https://your-sentry-dsn
