# ═══════════════════════════════════════════════════════════════
# Production Environment Variables
# Real Estate OS - نظام تشغيل المكتب العقاري
# ═══════════════════════════════════════════════════════════════

# API URL - IMPORTANT: Change this to your production API URL
# This is the URL where the API backend is accessible
NEXT_PUBLIC_API_URL=https://aqar.souqdev.com

# For local development, use:
# NEXT_PUBLIC_API_URL=http://localhost:3102

# ═══════════════════════════════════════════════════════════════
# Database (API Backend - set in API .env)
# ═══════════════════════════════════════════════════════════════
# DATABASE_URL="postgresql://user:password@localhost:5432/realestate"
# REDIS_URL="redis://localhost:6379"

# ═══════════════════════════════════════════════════════════════
# Authentication
# ═══════════════════════════════════════════════════════════════
# JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
# JWT_EXPIRES_IN="7d"

# ═══════════════════════════════════════════════════════════════
# External Services (Optional)
# ═══════════════════════════════════════════════════════════════
# ETA (Egyptian Tax Authority)
# ETA_CLIENT_ID="your-eta-client-id"
# ETA_CLIENT_SECRET="your-eta-client-secret"
# ETA_ENVIRONMENT="production"

# WhatsApp Business API
# WHATSAPP_TOKEN="your-whatsapp-token"
# WHATSAPP_PHONE_ID="your-phone-id"

# AI Provider (optional - for AI features)
# AI_PROVIDER="gemini"
# GEMINI_API_KEY="your-gemini-api-key"
