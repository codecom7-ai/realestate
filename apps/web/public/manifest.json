{
  "name": "نظام المكتب العقاري",
  "short_name": "العقاري",
  "description": "نظام تشغيل متكامل للمكاتب العقارية المصرية",
  "lang": "ar",
  "dir": "rtl",
  "start_url": "/ar/dashboard",
  "display": "standalone",
  "orientation": "portrait-primary",
  "scope": "/",
  "theme_color": "#1e40af",
  "background_color": "#ffffff",
  "categories": ["business", "finance", "productivity"],
