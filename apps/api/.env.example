# ═══════════════════════════════════════════════════════════════════════════
# نظام تشغيل المكتب العقاري المصري - ملف المتغيرات البيئية
# Egyptian Real Estate Office Operating System - Environment Variables
# ═══════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# التطبيق الرئيسي / Application
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# حالة الإعداد - يتغير تلقائياً بعد اكتمال الإعداد
# Setup status - automatically changes after setup completion
SETUP_DONE=false
ORG_ID=

# ─────────────────────────────────────────────────────────────────────────────
# قاعدة البيانات / Database (PostgreSQL 17)
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/realestate_os

# ─────────────────────────────────────────────────────────────────────────────
# Redis 7.4 - التخزين المؤقت والطوابير
# ─────────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────────────────────────────────────
# JWT Authentication - RS256
# ─────────────────────────────────────────────────────────────────────────────
# توليد المفاتيح:
# openssl genrsa -out private.key 2048
# openssl rsa -in private.key -pubout -out public.key

JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# ─────────────────────────────────────────────────────────────────────────────
# التشفير / Encryption
# ─────────────────────────────────────────────────────────────────────────────
# مفتاح 32 بايت للتشفير (generate: openssl rand -hex 32)
ENCRYPTION_KEY=your-32-character-hex-encryption-key-here

# ─────────────────────────────────────────────────────────────────────────────
# ETA - الفوترة الإلكترونية المصرية
# Egyptian Tax Authority - E-Invoicing
# ─────────────────────────────────────────────────────────────────────────────
# بيئة الاختبار (Preprod)
ETA_IDENTITY_URL=https://id.preprod.eta.gov.eg
ETA_API_URL=https://api.preprod.invoicing.eta.gov.eg

# بيانات العميل (من بوابة ETA)
ETA_CLIENT_ID=your-eta-client-id
ETA_CLIENT_SECRET=your-eta-client-secret

# ─────────────────────────────────────────────────────────────────────────────
# AI Providers - مزودي الذكاء الاصطناعي
# ─────────────────────────────────────────────────────────────────────────────

# Anthropic Claude (Tier 1 & 2)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Google AI Gemini (Tier 3 - Vision & OCR)
GOOGLE_AI_API_KEY=AIza-your-google-ai-api-key

# OpenRouter (Fallback & Tier 4)
OPENROUTER_API_KEY=sk-or-your-openrouter-api-key

# ─────────────────────────────────────────────────────────────────────────────
# بوابات الدفع / Payment Gateways
# ─────────────────────────────────────────────────────────────────────────────

# Paymob
PAYMOB_API_KEY=your-paymob-api-key
PAYMOB_INTEGRATION_ID=your-integration-id
PAYMOB_IFRAME_ID=your-iframe-id
PAYMOB_HMAC_SECRET=your-hmac-secret

# Fawry
FAWRY_MERCHANT_CODE=your-merchant-code
FAWRY_SECURITY_HASH=your-security-hash

# ─────────────────────────────────────────────────────────────────────────────
# التخزين السحابي / Cloud Storage (Cloudflare R2)
# ─────────────────────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY=your-access-key
R2_SECRET_KEY=your-secret-key
R2_BUCKET_NAME=realestate-os-dev
R2_PUBLIC_URL=https://your-bucket.your-domain.com

# ─────────────────────────────────────────────────────────────────────────────
# WhatsApp Business API
# ─────────────────────────────────────────────────────────────────────────────
WHATSAPP_TOKEN=your-whatsapp-business-token
WHATSAPP_PHONE_ID=your-phone-number-id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token

# ─────────────────────────────────────────────────────────────────────────────
# n8n Automation
# ─────────────────────────────────────────────────────────────────────────────
N8N_URL=http://localhost:5678
N8N_API_KEY=your-n8n-api-key

# ─────────────────────────────────────────────────────────────────────────────
# Firebase (Push Notifications)
# ─────────────────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# ─────────────────────────────────────────────────────────────────────────────
# السجلات والمراقبة / Logging & Monitoring
# ─────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
SENTRY_DSN=https://your-sentry-dsn

# ─────────────────────────────────────────────────────────────────────────────
# ملاحظات مهمة / Important Notes
# ─────────────────────────────────────────────────────────────────────────────
# 
# 1. لا ترفع هذا الملف للمستودع - ضعه في .gitignore
#    DO NOT commit this file to version control
#
# 2. للإنتاج، استخدم متغيرات البيئة من مزود الخدمة
#    For production, use environment variables from your hosting provider
#
# 3. توليد مفاتيح JWT:
#    Generate JWT keys:
#    openssl genrsa -out private.key 2048
#    openssl rsa -in private.key -pubout -out public.key
#
# 4. للحصول على بيانات ETA:
#    Register at: https://invoicing.eta.gov.eg/
#    Use Preprod for testing, Production for live
#
# 5. مفاتيح AI:
#    - Claude: https://console.anthropic.com/
#    - Gemini: https://makersuite.google.com/app/apikey
#    - OpenRouter: https://openrouter.ai/
