# ═══════════════════════════════════════════════════════════════
# Production Environment Variables
# Real Estate OS API Backend - نظام تشغيل المكتب العقاري
# ═══════════════════════════════════════════════════════════════

# Database
DATABASE_URL="postgresql://realestate:your_password@localhost:5432/realestate"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production-min-32-chars"
JWT_EXPIRES_IN="7d"

# Application
NODE_ENV="production"
PORT=3102

# ═══════════════════════════════════════════════════════════════
# ETA (Egyptian Tax Authority) - Electronic Invoicing
# ═══════════════════════════════════════════════════════════════
ETA_CLIENT_ID="your-eta-client-id"
ETA_CLIENT_SECRET="your-eta-client-secret"
ETA_ENVIRONMENT="production"

# ═══════════════════════════════════════════════════════════════
# Storage (Cloudflare R2 / S3)
# ═══════════════════════════════════════════════════════════════
R2_ACCOUNT_ID="your-account-id"
R2_ACCESS_KEY_ID="your-access-key"
R2_SECRET_ACCESS_KEY="your-secret-key"
R2_BUCKET_NAME="realestate-uploads"
R2_PUBLIC_URL="https://your-bucket.your-domain.com"

# ═══════════════════════════════════════════════════════════════
# WhatsApp Business API (Optional)
# ═══════════════════════════════════════════════════════════════
WHATSAPP_TOKEN="your-whatsapp-token"
WHATSAPP_PHONE_ID="your-phone-id"

# ═══════════════════════════════════════════════════════════════
# AI Provider (for AI Copilot features)
# ═══════════════════════════════════════════════════════════════
AI_PROVIDER="gemini"
GEMINI_API_KEY="your-gemini-api-key"

# Required additions
SETUP_DONE=true
INTERNAL_API_URL=http://localhost:3102
