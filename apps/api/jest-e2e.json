{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": ["ts-jest", {
      "isolatedModules": true
    }]
  },
  "moduleNameMapper": {
    "^@realestate/shared-types$": "<rootDir>/../../packages/shared-types/src/index.ts",
    "^@realestate/shared-utils$": "<rootDir>/../../packages/shared-utils/src/index.ts"
  }
}
